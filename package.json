{
  "name": "ci-pipeline-app",
  "version": "1.0.0",
  "description": "A minimal Node.js app for the CI pipeline demonstration",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "lint": "eslint src/ test/",
    "test": "jest --ci --coverage",
    "build": "mkdir -p dist && cp -r src/* dist/",
    "audit:ci": "npm audit --audit-level=critical"
  },
  "keywords": [],
  "author": "Nia's Team",
  "license": "ISC",
  "dependencies": {
    "express": "^4.22.1"
  },
  "devDependencies": {
    "eslint": "8.57.0",
    "jest": "29.7.0",
    "supertest": "7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
